TELEGRAM_TOKEN=replace-me

# Optional
CACHE_CHAT_ID=
ADMIN_USER_IDS=

# Search thresholds
MIN_BM25_SCORE=4.0
MIN_CLIP_SCORE=0.23
MIN_CLIP_RERANK_SCORE=0.35
MIN_CLIP_FALLBACK_SCORE=0.28

# Runtime storage inside the container
APP_DATA_DIR=/data

# HuggingFace fallback dataset
DATASET_NAME=DIvest1ng/meme
DATASET_SPLIT=train

# Mounted artifacts on the server
DATASET_PATH=/artifacts/meme_enriched
CLIP_MODEL_PATH=/artifacts/clip_finetuned
CLIP_INDEX_PATH=/artifacts/clip.index
CLIP_META_PATH=/artifacts/clip_meta.npy

# Only for OpenCLIP .pt/.pth checkpoints
OPENCLIP_ARCH=xlm-roberta-base-ViT-B-32
OPENCLIP_PRETRAINED=laion5b_s13b_b90k
